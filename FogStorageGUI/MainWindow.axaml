<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:FogStorageGUI.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        MinWidth="500"
        MaxWidth="500"
        MinHeight="700"
        MaxHeight="700"
        x:Class="FogStorageGUI.MainWindow"
        Title="FogStorage"
        WindowStartupLocation="CenterScreen"
        x:DataType="viewModels:MainWindowViewModel">
        <Window.DataContext>
                <viewModels:MainWindowViewModel />
        </Window.DataContext>
        
        <Border BorderBrush="Indigo" BorderThickness="5" Padding="40" Margin="20">
                <StackPanel>
                        <TextBlock FontSize="48" HorizontalAlignment="Left" Margin="40" x:Name="AppName">Fog Storage</TextBlock>
                        <Button Content="Save file" HorizontalContentAlignment="Center"  HorizontalAlignment="Center"
                                Width="120" Click="OnSaveFile" Margin="10" IsEnabled="True"/> 
                        
                        <ComboBox ItemsSource="{Binding Files}" SelectedItem="{Binding SelectedItem, Mode=TwoWay}" HorizontalAlignment="Center" HorizontalContentAlignment="Left"
                                  Width="300" Margin="20" PlaceholderText="Choose a file"></ComboBox>
                        
                        <Button Content="Restore file" HorizontalContentAlignment="Center" HorizontalAlignment="Center"
                                Width="120" Click="OnRestoreFile" Margin="50" IsEnabled="True" />
                        <Button Content="Delete file" HorizontalContentAlignment="Center" HorizontalAlignment="Center"
                                Width="120" Click="OnDeleteFile" Margin="50" IsEnabled="True" />
                </StackPanel>
        </Border> 
</Window>

